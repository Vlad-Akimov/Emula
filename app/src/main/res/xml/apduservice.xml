<?xml version="1.0" encoding="utf-8"?>
<host-apdu-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/service_description"
    android:requireDeviceUnlock="false">

    <!-- NDEF Type 4 Tag AIDs -->
    <aid-group
        android:description="@string/aid_group_ndef"
        android:category="other">

        <!-- Standard NDEF Type 4 Tag AID (NFC Forum) -->
        <aid-filter android:name="D2760000850101"/>
        <aid-filter android:name="D2760000850100"/>
        <aid-filter android:name="D2760000850102"/>
        <aid-filter android:name="D2760000850110"/>

    </aid-group>

    <!-- MIFARE Classic Emulation AIDs -->
    <aid-group
        android:description="@string/aid_group_mifare"
        android:category="other">

        <!-- Generic MIFARE AID for HCE -->
        <aid-filter android:name="F0010203040506"/>

        <!-- Troika specific -->
        <aid-filter android:name="F0123456789012"/>

        <!-- University card specific -->
        <aid-filter android:name="F0987654321098"/>

    </aid-group>

    <!-- Fallback for broad compatibility -->
    <aid-group
        android:description="@string/aid_group_fallback"
        android:category="other">

        <!-- Catch-all for unknown cards -->
        <aid-filter android:name="FFFFFFFFFFFFFFFF"/>

    </aid-group>

</host-apdu-service>